# App Postgres (orchestrator/MCP/ingestion shared schema)
DATABASE_URL=postgresql+asyncpg://agenticforge:agenticforge@localhost:5432/agenticforge

# MCP server
MCP_SERVER_PORT=8100
MCP_SERVER_URL=http://localhost:8100/mcp
MCP_REQUIRE_AUTH=true

# Demo weather API (M2 target for the first manual MCP tool)
DEMO_API_PORT=9000
DEMO_API_BASE_URL=http://localhost:9000

# Demo DevOps/code-review API (M2 target for the devops MCP tools)
DEVOPS_API_PORT=9001
DEVOPS_API_BASE_URL=http://localhost:9001

# Model provider credentials (fill in what you use; leave blank to skip a provider)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
OLLAMA_BASE_URL=http://localhost:11434
VLLM_BASE_URL=

# Langfuse (self-hosted, see infra/docker-compose/docker-compose.langfuse.yml)
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
